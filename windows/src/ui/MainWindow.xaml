<Window x:Class="SoundBridge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SoundBridge.UI"
        Title="SoundBridge"
        MinWidth="400" MinHeight="700"
        Width="450" Height="800"
        Background="#FF1E1E1E"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <local:BoolToStatusColorConverter x:Key="BoolToStatusColorConverter"/>
        <local:LevelToColorConverter x:Key="LevelToColorConverter"/>
        <local:LevelToPercentConverter x:Key="LevelToPercentConverter"/>
        <local:BoolToIconConverter x:Key="BoolToIconConverter"/>
        <local:BoolToConnectTextConverter x:Key="BoolToConnectTextConverter"/>
        <local:BoolToMuteIconConverter x:Key="BoolToMuteIconConverter"/>
        <local:BoolToMuteTextConverter x:Key="BoolToMuteTextConverter"/>
        <local:BoolToPauseIconConverter x:Key="BoolToPauseIconConverter"/>
        <local:BoolToPauseTextConverter x:Key="BoolToPauseTextConverter"/>
        <local:VolumeToPercentConverter x:Key="VolumeToPercentConverter"/>
        <local:VolumeToIconConverter x:Key="VolumeToIconConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:MixRatioToPercentConverter x:Key="MixRatioToPercentConverter"/>
        <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter"/>
        <local:BoolToScanTextConverter x:Key="BoolToScanTextConverter"/>
        <local:CollectionToVisibilityConverter x:Key="CollectionToVisibilityConverter"/>
        <local:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibilityConverter"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="DescriptionText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FF999999"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 连接状态卡片 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}"
                Background="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse Width="12" Height="12" Margin="0,0,8,0"
                         Fill="{Binding IsConnected, Converter={StaticResource BoolToStatusColorConverter}}"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="16" FontWeight="SemiBold" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- 音频电平 -->
        <Grid Grid.Row="1" Height="200" HorizontalAlignment="Center" Margin="0,0,0,8">
            <ProgressBar x:Name="AudioLevelBar" Value="{Binding AudioLevel}" Maximum="1"
                         Width="180" Height="180"
                         Style="{x:Null}"
                         Foreground="{Binding AudioLevel, Converter={StaticResource LevelToColorConverter}}"
                         Background="#FF333333" BorderThickness="0"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding AudioLevel, Converter={StaticResource LevelToPercentConverter}}"
                           FontSize="36" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Audio Level" FontSize="14" Foreground="#FF999999"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 音量控制 -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{Binding Volume, Converter={StaticResource VolumeToIconConverter}}"
                               VerticalAlignment="Center" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Volume" Style="{StaticResource SectionTitle}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Volume, Converter={StaticResource VolumeToPercentConverter}}"
                               Foreground="#FF999999" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="8,0,0,0"/>
                </StackPanel>
                <Slider Minimum="0" Maximum="100"
                        Value="{Binding Volume, Mode=TwoWay}"
                        TickFrequency="1" IsSnapToTickEnabled="True"/>
            </StackPanel>
        </Border>

        <!-- 控制按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Button Command="{Binding ToggleConnectionCommand}"
                    Height="56" MinWidth="160" Margin="0,0,8,0"
                    IsEnabled="{Binding IsConnecting, Converter={StaticResource InvertBoolConverter}}"
                    Background="#FF0078D4" Foreground="White" BorderThickness="0">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar IsIndeterminate="{Binding IsConnecting}" Width="20" Height="20"
                                 Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToIconConverter}}"
                               Visibility="{Binding IsConnecting, Converter={StaticResource InvertBoolToVisibilityConverter}}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Connecting..."
                               Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibilityConverter}}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToConnectTextConverter}}"
                               Visibility="{Binding IsConnecting, Converter={StaticResource InvertBoolToVisibilityConverter}}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding TogglePauseCommand}"
                    Height="56" MinWidth="120" Margin="0,0,8,0"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding IsPaused, Converter={StaticResource BoolToPauseIconConverter}}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding IsPaused, Converter={StaticResource BoolToPauseTextConverter}}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding ToggleMuteCommand}"
                    Height="56" MinWidth="120">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding IsMuted, Converter={StaticResource BoolToMuteIconConverter}}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding IsMuted, Converter={StaticResource BoolToMuteTextConverter}}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- 服务器配置 -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Server Configuration" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>
                <TextBlock Text="Server Address" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
                <TextBox Text="{Binding ServerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8" Margin="0,0,0,8"/>
                <TextBlock Text="Port" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
                <TextBox Text="{Binding ServerPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8"/>
            </StackPanel>
        </Border>

        <!-- 连接方式 -->
        <Border Grid.Row="5" Style="{StaticResource CardBorder}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="📡" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Connection Type" Style="{StaticResource SectionTitle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Style="{StaticResource DescriptionText}" Margin="0,0,0,8"
                           Text="WiFi LAN: auto-discover on same network. (WiFi Direct, USB/ADB, Bluetooth — planned, not yet available)"/>
                <ComboBox ItemsSource="{Binding ConnectionTypeNames}"
                          SelectedIndex="{Binding SelectedConnectionType, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" Padding="8">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="WiFi 局域网">
                                    <Setter Property="IsEnabled" Value="True"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- 设备发现 -->
        <Border Grid.Row="6" Style="{StaticResource CardBorder}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Device Discovery" Style="{StaticResource SectionTitle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Style="{StaticResource DescriptionText}" Margin="0,0,0,8"
                           Text="Scan for SoundBridge devices on your local network."/>
                <Button Command="{Binding ScanDevicesCommand}"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InvertBoolConverter}}"
                        HorizontalAlignment="Stretch" Padding="8" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <ProgressBar IsIndeterminate="{Binding IsScanning}" Width="16" Height="16"
                                     Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Background="Transparent" Foreground="White" BorderThickness="0" Margin="0,0,4,0"/>
                        <TextBlock Text="🔍"
                                   Visibility="{Binding IsScanning, Converter={StaticResource InvertBoolToVisibilityConverter}}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding IsScanning, Converter={StaticResource BoolToScanTextConverter}}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <ListBox ItemsSource="{Binding DiscoveredDevices}"
                         Visibility="{Binding DiscoveredDevices, Converter={StaticResource CollectionToVisibilityConverter}}"
                         MaxHeight="200" Margin="0,0,0,8"
                         SelectionChanged="DeviceList_SelectionChanged"/>
                <TextBlock Text="No devices found"
                           Style="{StaticResource DescriptionText}"
                           Visibility="{Binding DiscoveredDevices, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- 音频模式 -->
        <Border Grid.Row="7" Style="{StaticResource CardBorder}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🎵" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Audio Mode" Style="{StaticResource SectionTitle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Style="{StaticResource DescriptionText}" Margin="0,0,0,8"
                           Text="Balanced: 50-100ms delay. High Quality: 48kHz/24bit. Low Latency: &lt;30ms."/>
                <ComboBox ItemsSource="{Binding AudioModeOptions, ElementName=Root}"
                          SelectedIndex="{Binding SelectedAudioMode, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" Padding="8"/>
            </StackPanel>
        </Border>

        <!-- 混音比例 -->
        <Border Grid.Row="8" Style="{StaticResource CardBorder}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🎚" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Mix Ratio" Style="{StaticResource SectionTitle}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MixRatio, Converter={StaticResource MixRatioToPercentConverter}}"
                               Foreground="#FF999999" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="8,0,0,0"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PC" Foreground="#FF999999"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100"
                            Value="{Binding MixRatio, Mode=TwoWay}"
                            TickFrequency="5" IsSnapToTickEnabled="True"/>
                    <TextBlock Grid.Column="2" Text="Phone" Foreground="#FF999999"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 开机自启 -->
        <Border Grid.Row="9" Style="{StaticResource CardBorder}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="⚙" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Auto-start" Style="{StaticResource SectionTitle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Style="{StaticResource DescriptionText}" Margin="0,0,0,8"
                           Text="Launch SoundBridge automatically when Windows starts (minimized to tray)."/>
                <CheckBox IsChecked="{Binding IsAutoStartEnabled, Mode=TwoWay}"
                          Content="Enabled" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- 音质档位 -->
        <Border Grid.Row="10" Style="{StaticResource CardBorder}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🎚" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Audio Profile" Style="{StaticResource SectionTitle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Style="{StaticResource DescriptionText}" Margin="0,0,0,8"
                           Text="Higher quality uses more bandwidth. Auto adjusts based on network conditions."/>
                <ComboBox x:Name="AudioProfileComboBox"
                          SelectedIndex="1"
                          SelectionChanged="AudioProfileComboBox_SelectionChanged"
                          HorizontalAlignment="Stretch" Padding="8" Margin="0,0,0,8">
                    <ComboBoxItem Content="Bandwidth Saving"/>
                    <ComboBoxItem Content="Standard"/>
                    <ComboBoxItem Content="High Quality"/>
                    <ComboBoxItem Content="Lossless"/>
                    <ComboBoxItem Content="High Resolution"/>
                    <ComboBoxItem Content="Studio Master"/>
                    <ComboBoxItem Content="Auto"/>
                </ComboBox>
                <CheckBox x:Name="AutoProfileToggle"
                          Content="Auto Mode"
                          IsChecked="True"
                          Checked="AutoProfileToggle_Changed"
                          Unchecked="AutoProfileToggle_Changed"
                          Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- 均衡器 -->
        <Expander Grid.Row="11" Header="Equalizer"
                  HorizontalAlignment="Stretch" Foreground="White" Margin="0,0,0,8">
            <Border Style="{StaticResource CardBorder}" CornerRadius="0,0,12,12">
                <StackPanel>
                    <ComboBox x:Name="EqPresetComboBox"
                              SelectedIndex="0"
                              SelectionChanged="EqPresetComboBox_SelectionChanged"
                              HorizontalAlignment="Stretch" Padding="8" Margin="0,0,0,12">
                        <ComboBoxItem Content="Flat"/>
                        <ComboBoxItem Content="Gaming"/>
                        <ComboBoxItem Content="Music"/>
                        <ComboBoxItem Content="Voice"/>
                        <ComboBoxItem Content="Bass Boost"/>
                        <ComboBoxItem Content="Treble Boost"/>
                    </ComboBox>

                    <TextBlock Text="31 Hz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand0" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="62 Hz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand1" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="125 Hz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand2" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="250 Hz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand3" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="500 Hz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand4" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="1 kHz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand5" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="2 kHz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand6" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="4 kHz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand7" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="8 kHz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand8" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged" Margin="0,0,0,4"/>
                    <TextBlock Text="16 kHz" Foreground="#FFCCCCCC" Margin="0,4,0,2"/>
                    <Slider x:Name="EqBand9" Minimum="-12" Maximum="12" Value="0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="EqBand_ValueChanged"/>
                </StackPanel>
            </Border>
        </Expander>

        <Grid Grid.Row="12"/>
    </Grid>
</Window>
